<h1><%= @place.name %></h1>

<% @entries.each do |entry| %>
  <div>
    <strong><%= entry.title %></strong><br>
    <%= entry.occurred_on %><br>
    <p><%= entry.description %></p>
  </div>
<% end %>

<p><a href="/entries/new?place_id=<%= @place.id %>">New Post</a></p>

<p><a href="/places">Back to all places</a></p>